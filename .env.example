# Copy this file to ".env" and paste your real key. ".env" is gitignored.
#   cp .env.example .env
# Then run: npm start

ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Salesforce (username + password + security token) ---------------------
# The agents read/write your org via these. Leave blank to use the mock DB.
# Security token: Setup -> reset/view "My Security Token" (emailed to you).
SF_USERNAME=you@example.com
SF_PASSWORD=your-password
SF_SECURITY_TOKEN=your-security-token
# Use https://test.salesforce.com for a sandbox:
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=60.0

# Optional overrides:
# AGENT_SIM_MODEL=claude-opus-4-8
# AGENT_SIM_API_PORT=4000
# AGENT_SIM_CLIENT_PORT=3000
